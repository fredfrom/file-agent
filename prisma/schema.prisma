generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @db.VarChar(255)
  createdAt DateTime   @default(now()) @map("created_at")
  documents Document[]

  @@map("projects")
}

model Document {
  id          String                  @id @default(uuid()) @db.Uuid
  projectId   String                  @map("project_id") @db.Uuid
  virtualPath String                  @map("virtual_path")
  folder      String
  filename    String
  extension   String                  @db.VarChar(10)
  content     String
  metadata    Json                    @default("{}")
  contentTsv  Unsupported("tsvector")? @map("content_tsv")
  createdAt   DateTime                @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, virtualPath])
  @@index([projectId])
  @@index([virtualPath])
  @@index([folder])
  @@map("documents")
}

model Conversation {
  id        String    @id @default(uuid()) @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  title     String    @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  messages  Message[]

  @@index([projectId])
  @@index([updatedAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String   @db.VarChar(20)
  parts          Json
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

model AccessLog {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  virtualPath String   @map("virtual_path")
  source      String   @db.VarChar(10)
  accessOrder Int      @map("access_order")
  sessionId   String   @map("session_id") @db.Uuid
  accessedAt  DateTime @map("accessed_at") @default(now())

  @@index([projectId])
  @@index([sessionId])
  @@index([accessedAt])
  @@map("access_logs")
}
