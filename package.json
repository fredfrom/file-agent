{
  "name": "file-agent",
  "version": "0.1.0",
  "description": "AI agent that navigates construction project documents via bash commands against a virtual filesystem",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/USER/file-agent.git"
  },
  "keywords": [
    "ai-agent",
    "construction",
    "filesystem",
    "bash",
    "nextjs",
    "vercel-ai-sdk",
    "german"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx --env-file=.env.local src/eval/run.ts",
    "eval:compare": "tsx --env-file=.env.local src/eval/compare-run.ts",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate && node -e \"const fs=require('fs'),p='node_modules/bash-tool/package.json',d=JSON.parse(fs.readFileSync(p));d.exports['.'].default=d.exports['.'].import;fs.writeFileSync(p,JSON.stringify(d,null,2))\" 2>/dev/null || true"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/react": "^3.0.136",
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@tanstack/react-query": "^5.95.0",
    "ai": "^6.0.134",
    "bash-tool": "^1.3.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "just-bash": "^2.14.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "pdfkit": "^0.18.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
